{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "react-router dev --host 0.0.0.0",
    "build": "pnpm build:ssr",
    "build:spa": "set BBSGO_WEB_SPA=true && react-router build && node scripts/prepare-spa-build.mjs",
    "build:ssr": "react-router build",
    "start": "node scripts/serve-ssr.mjs",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@react-router/node": "^7.15.0",
    "@tiptap/core": "^3.23.1",
    "@tiptap/extension-color": "^3.23.1",
    "@tiptap/extension-horizontal-rule": "^3.23.1",
    "@tiptap/extension-image": "^3.23.1",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/extension-task-item": "^3.23.1",
    "@tiptap/extension-task-list": "^3.23.1",
    "@tiptap/extension-text-align": "^3.23.1",
    "@tiptap/extension-text-style": "^3.23.1",
    "@tiptap/extension-typography": "^3.23.1",
    "@tiptap/extension-underline": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@tiptap/suggestion": "^3.23.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "go-captcha-react": "1.0.4",
    "i18next": "^26.2.0",
    "input-otp": "^1.4.2",
    "isbot": "^5",
    "lucide-react": "^1.14.0",
    "md-editor-rt": "^6.5.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.8",
    "react-resizable-panels": "^4.11.1",
    "react-router": "^7.15.0",
    "react-router-dom": "^7.15.0",
    "recharts": "3.8.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@react-router/dev": "^7.15.0",
    "@react-router/fs-routes": "^7.15.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.12"
  }
